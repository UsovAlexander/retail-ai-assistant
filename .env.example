# Copy to .env and fill in. .env is git-ignored — never commit secrets.

# --- ClickHouse (already running locally; HTTP interface) ---
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=1234
CH_DATABASE=retail_demo

# --- Qdrant (already running locally) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Ollama (already running locally; OpenAI-compatible API) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:14b

# --- Embeddings ---
EMBEDDING_MODEL=cointegrated/LaBSE-en-ru

# --- Telegram bot (stage 9) ---
TELEGRAM_BOT_TOKEN=
# Comma-separated whitelist of Telegram user IDs, e.g. 12345,67890
TELEGRAM_ALLOWED_USERS=

# --- Misc ---
LOG_LEVEL=INFO
# Directory for generated artifacts (charts, xlsx). Defaults to a temp dir if unset.
ARTIFACTS_DIR=
