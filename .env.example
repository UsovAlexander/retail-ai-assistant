# Copy to .env and fill in. .env is git-ignored — never commit real secrets here.

# --- ClickHouse (already running locally; HTTP interface) ---
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=            # set your local ClickHouse password
CH_DATABASE=retail_demo

# --- Qdrant (already running locally) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Ollama (local backend; OpenAI-compatible API) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:14b

# --- LLM backend selection: local | external | auto ---
#   local    = always Ollama (default; keeps the system fully local)
#   external = always the external endpoint below
#   auto     = try external first, fall back to local on error / rate limit
LLM_BACKEND=local
# Any OpenAI-compatible endpoint (OpenAI, Groq, OpenRouter, Anthropic-compat, ...).
# Example shown for Groq.
EXTERNAL_LLM_BASE_URL=https://api.groq.com/openai/v1
EXTERNAL_LLM_API_KEY=                # your provider API key
EXTERNAL_LLM_MODEL=llama-3.3-70b-versatile

# --- Embeddings ---
EMBEDDING_MODEL=cointegrated/LaBSE-en-ru

# --- Telegram bot (stage 9) ---
TELEGRAM_BOT_TOKEN=                 # from @BotFather
TELEGRAM_ALLOWED_USERS=            # comma-separated Telegram user IDs, e.g. 12345,67890

# --- Misc ---
LOG_LEVEL=INFO
# Directory for generated artifacts (charts, xlsx). Defaults to a temp dir if unset.
ARTIFACTS_DIR=
